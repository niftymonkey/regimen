{
  "name": "@regimen/otlp-bridge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "bridge": "./src/cli.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun test",
    "start": "bun run src/cli.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bun": "latest",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@regimen/shared": "workspace:*"
  }
}
